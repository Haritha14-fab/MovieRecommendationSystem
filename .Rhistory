source("Scripts/global_config.R")
# UBCF (User Based)
ubcf_model <- Recommender(
rating_matrix,
method = "UBCF",
parameter = list(method = "cosine", nn = 30)
)
# IBCF (Item Based)
ibcf_model <- Recommender(
rating_matrix,
method = "IBCF",
parameter = list(k = 30)
)
