# Generate recommendations for User 1
ubcf_pred <- predict(ubcf_model, rating_matrix, type = "ratings")
ibcf_pred <- predict(ibcf_model, rating_matrix, type = "ratings")
ubcf_mat <- as(ubcf_pred, "matrix")
ibcf_mat <- as(ibcf_pred, "matrix")
# Hybrid
alpha <- 0.6
beta <- 0.4
hybrid_matrix <- (alpha * ubcf_mat) + (beta * ibcf_mat)
# Convert to ranked format (IMPORTANT FOR API)
user1 <- sort(hybrid_matrix[1, ], decreasing = TRUE)
recommendations <- data.frame(
Movie = names(user1),
Predicted_Rating = as.numeric(user1),
Rank = 1:length(user1),
Match_Percentage = round(user1 * 20, 2),   # scale to %
Recommendation_Strength = ifelse(user1 > 4, "High",
ifelse(user1 > 3, "Medium", "Low"))
)
head(recommendations, 10)
