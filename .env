# Flask Movie Recommendation System Environment Configuration
# Get TMDb API key from: https://www.themoviedb.org/settings/api

# TMDb API Key for poster lookup
TMDB_API_KEY=your_tmdb_key_here

# OMDb API Key for movie details (default provided, may need replacement if rate-limited)
OMDB_API_KEY=4c8b368d

# Flask Secret Key for session management (CHANGE THIS IN PRODUCTION!)
FLASK_SECRET=dev_secret_key_change_in_production_abc123xyz

# Database configuration
DATABASE_PATH=users.db

# R Pipeline toggle
ALLOW_R_PIPELINE=true

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
