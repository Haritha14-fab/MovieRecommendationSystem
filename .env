# Example environment variables for MovieRecommendationSystem
# Twilio (for SMS OTP)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890
# Optional: send test SMS only when this is true
ALLOW_TWILIO_TEST=false

# SMTP (fallback or for email OTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=yourpassword

# App behavior
FLASK_SECRET=some_random_secret
DEBUG_OTP=true  # set to true only for development
ALLOW_R_PIPELINE=false
RSCRIPT_CMD=Rscript
TMDB_API_KEY=
OMDB_API_KEY=
